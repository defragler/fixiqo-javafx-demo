<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="350.0" prefWidth="450.0"
  styleClass="modal" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.defragler.fixiqo.views.controllers.modals.AccountModalWindowController">
  <padding>
    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
  </padding>

  <!-- Window Content -->
  <GridPane alignment="CENTER" vgap="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
    <columnConstraints>
      <ColumnConstraints hgrow="NEVER"/>
      <ColumnConstraints hgrow="NEVER"/>
      <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="NEVER"/>
    </rowConstraints>

    <!-- Avatar Section -->
    <GridPane vgap="5.0">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Avatar"/>
      <ImageView fx:id="avatarPreview"
        fitWidth="200"
        fitHeight="200"
        preserveRatio="true"
        smooth="true"
        GridPane.rowIndex="1"/>
    </GridPane>

    <Button mnemonicParsing="false" onAction="#loadImage" text="Load image"
      GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="TOP"/>

    <Separator orientation="VERTICAL" GridPane.columnIndex="1" GridPane.rowSpan="2"/>

    <!-- Account Section -->
    <GridPane vgap="5.0" GridPane.columnIndex="2">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Account"/>
      <VBox alignment="CENTER" fillWidth="false" spacing="15.0" GridPane.rowIndex="1">
        <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0">
          <Label alignment="CENTER" text="Username"/>
          <TextField fx:id="usernameField" promptText="Username"/>
        </VBox>
        <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0">
          <Label text="Password"/>
          <PasswordField fx:id="passwordField" promptText="Password"/>
        </VBox>
        <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0">
          <Label text="Email"/>
          <TextField fx:id="emailField" promptText="Email"/>
        </VBox>
        <Label fx:id="errorLabel" alignment="CENTER" contentDisplay="CENTER" opacity="0"
          styleClass="danger" textAlignment="CENTER" visible="false"/>
      </VBox>
    </GridPane>

    <!-- Actions Section -->
    <GridPane vgap="5.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <HBox alignment="CENTER" spacing="5.0" GridPane.rowIndex="1">
        <Button defaultButton="true" mnemonicParsing="false" onAction="#save" prefWidth="100.0"
          text="Save"/>
        <Button cancelButton="true" mnemonicParsing="false" onAction="#cancel" prefWidth="100.0"
          text="Cancel"/>
      </HBox>
      <Label opacity="0.5" text="Actions"/>
    </GridPane>
  </GridPane>
</AnchorPane>
