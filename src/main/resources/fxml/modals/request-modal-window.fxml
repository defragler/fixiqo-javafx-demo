<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="650.0" prefWidth="1050.0"
  styleClass="modal" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.defragler.fixiqo.views.controllers.modals.RequestModalWindowController">
  <padding>
    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
  </padding>

  <!-- Window Content -->
  <GridPane hgap="5.0" vgap="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
    <columnConstraints>
      <ColumnConstraints hgrow="NEVER" percentWidth="30.0"/>
      <ColumnConstraints hgrow="NEVER" percentWidth="30.0"/>
      <ColumnConstraints hgrow="ALWAYS"/>
      <ColumnConstraints hgrow="NEVER"/>
    </columnConstraints>
    <rowConstraints>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>

    <!-- Details Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0">
      <columnConstraints>
        <ColumnConstraints hgrow="NEVER" prefWidth="50.0"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="SOMETIMES"/>
        <RowConstraints vgrow="ALWAYS"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Details" GridPane.columnSpan="2"/>
      <Label text="Date" textAlignment="RIGHT" GridPane.halignment="RIGHT" GridPane.rowIndex="1"/>
      <DatePicker fx:id="detailsDateField" maxWidth="-Infinity" promptText="xX.xX.xXxX"
        GridPane.columnIndex="1" GridPane.rowIndex="1"/>
      <Label text="№" textAlignment="RIGHT" GridPane.halignment="RIGHT" GridPane.rowIndex="2"/>
      <TextField fx:id="detailsIdField" editable="false" maxWidth="-Infinity" promptText="ID"
        GridPane.columnIndex="1" GridPane.rowIndex="2"/>

      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Client Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnIndex="1">
      <columnConstraints>
        <ColumnConstraints hgrow="NEVER" prefWidth="50.0"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Client" GridPane.columnSpan="2"/>
      <Label text="Name" textAlignment="RIGHT" GridPane.halignment="RIGHT" GridPane.rowIndex="1"/>
      <ComboBox fx:id="clientNameField" editable="true" maxWidth="-Infinity" promptText="Full Name"
        GridPane.columnIndex="1" GridPane.rowIndex="1"/>
      <Label text="Number" textAlignment="RIGHT" GridPane.halignment="RIGHT" GridPane.rowIndex="2"/>
      <TextField fx:id="clientNumberField" maxWidth="-Infinity" promptText="Phone Number"
        GridPane.columnIndex="1" GridPane.rowIndex="2"/>

      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Device Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnSpan="2"
      GridPane.rowIndex="1">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
        <ColumnConstraints hgrow="NEVER"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>

      <Label opacity="0.5" text="Device" GridPane.columnSpan="2"/>

      <GridPane hgap="5.0" vgap="5.0" GridPane.rowIndex="1">
        <columnConstraints>
          <ColumnConstraints hgrow="NEVER" prefWidth="50.0"/>
          <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
          <RowConstraints vgrow="ALWAYS"/>
          <RowConstraints vgrow="ALWAYS"/>
        </rowConstraints>
        <Label text="Type" textAlignment="RIGHT" GridPane.halignment="RIGHT"/>
        <ComboBox fx:id="deviceTypeField" maxWidth="-Infinity" promptText="Type"
          GridPane.columnIndex="1"/>
        <Label text="Brand" textAlignment="RIGHT" GridPane.halignment="RIGHT"
          GridPane.rowIndex="1"/>
        <ComboBox fx:id="deviceBrandField" editable="true" maxWidth="-Infinity"
          promptText="Manufacturer" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
      </GridPane>
      <Separator orientation="VERTICAL" GridPane.columnIndex="1" GridPane.rowSpan="2">
        <padding>
          <Insets bottom="5.0" top="5.0"/>
        </padding>
      </Separator>

      <GridPane hgap="5.0" vgap="5.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
        <columnConstraints>
          <ColumnConstraints hgrow="NEVER" prefWidth="50.0"/>
          <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
          <RowConstraints vgrow="ALWAYS"/>
          <RowConstraints vgrow="ALWAYS"/>
        </rowConstraints>

        <Label text="Model" textAlignment="RIGHT" GridPane.halignment="RIGHT"/>
        <TextField fx:id="deviceModelField" maxWidth="-Infinity" promptText="Model"
          GridPane.columnIndex="1"/>
        <Label text="Serial" textAlignment="RIGHT" GridPane.halignment="RIGHT"
          GridPane.rowIndex="1"/>
        <TextField fx:id="deviceSerialField" maxWidth="-Infinity" promptText="Serial number"
          GridPane.columnIndex="1" GridPane.rowIndex="1"/>

      </GridPane>
    </GridPane>

    <!-- Description Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnIndex="2"
      GridPane.columnSpan="2" GridPane.rowSpan="3">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Description"/>
      <TextArea fx:id="descriptionField" prefHeight="200.0" prefWidth="200.0"
        GridPane.rowIndex="1"/>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Accessories Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.rowIndex="2">
      <columnConstraints>
        <ColumnConstraints hgrow="NEVER"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Accessories" GridPane.columnSpan="2"/>
      <VBox spacing="5.0" GridPane.rowIndex="1">
        <Button mnemonicParsing="false" styleClass="additional-medium" text="+"/>
        <Button mnemonicParsing="false" styleClass="additional-medium" text="/"/>
        <Button mnemonicParsing="false" styleClass="additional-medium" text="-"/>
      </VBox>
      <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
        <CheckBox mnemonicParsing="false" text="Option 1"/>
        <CheckBox mnemonicParsing="false" text="Option 2"/>
        <CheckBox mnemonicParsing="false" text="Option 3"/>
        <CheckBox mnemonicParsing="false" text="Option 4"/>
        <CheckBox mnemonicParsing="false" text="Option 5"/>
      </VBox>

      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Status Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnIndex="1"
      GridPane.rowIndex="2">
      <columnConstraints>
        <ColumnConstraints hgrow="NEVER"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Status" GridPane.columnSpan="2"/>
      <VBox spacing="5.0" GridPane.rowIndex="1">
        <Button mnemonicParsing="false" styleClass="additional-medium" text="+"/>
        <Button mnemonicParsing="false" styleClass="additional-medium" text="/"/>
        <Button mnemonicParsing="false" styleClass="additional-medium" text="-"/>
      </VBox>

      <TableView fx:id="statusTable" prefHeight="125.0" GridPane.columnIndex="1"
        GridPane.rowIndex="1">
        <columns>
          <TableColumn fx:id="statusColumn" prefWidth="75.0" text="Status"/>
          <TableColumn fx:id="idColumn" prefWidth="75.0" text="Date"/>
        </columns>
        <columnResizePolicy>
          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
      </TableView>

      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Options & Materials Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnSpan="3"
      GridPane.rowIndex="3">
      <columnConstraints>
        <ColumnConstraints hgrow="NEVER"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <Label opacity="0.5" text="Options &amp; Materials" GridPane.columnSpan="2"/>
      <VBox spacing="5.0" GridPane.rowIndex="1">
        <Button mnemonicParsing="false" styleClass="additional-medium" text="+"/>
        <Button mnemonicParsing="false" styleClass="additional-medium" text="/"/>
        <Button mnemonicParsing="false" styleClass="additional-medium" text="-"/>
      </VBox>

      <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE"
        GridPane.columnIndex="1" GridPane.rowIndex="1">
        <Tab text="Options">
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
            <TableView fx:id="optionsTable" layoutY="7.0" prefHeight="200.0" prefWidth="200.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
              <columns>
                <TableColumn fx:id="optionsNameColumn" prefWidth="75.0" text="Name"/>
                <TableColumn fx:id="optionsPriceColumn" prefWidth="75.0" text="Price"/>
              </columns>
              <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
              </columnResizePolicy>
            </TableView>
          </AnchorPane>
        </Tab>

        <Tab text="Materials">
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
            <TableView fx:id="materialsTable" prefHeight="200.0" prefWidth="200.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
              <columns>
                <TableColumn fx:id="materialsNameColumn" prefWidth="75.0" text="Name"/>
                <TableColumn fx:id="materialsPriceColumn" prefWidth="75.0" text="Price"/>
              </columns>
              <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
              </columnResizePolicy>
            </TableView>
          </AnchorPane>
        </Tab>
      </TabPane>

      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Total Section -->
    <GridPane hgap="5.0" styleClass="bordered" GridPane.columnIndex="3" GridPane.rowIndex="3">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="ALWAYS"/>
        <RowConstraints vgrow="ALWAYS"/>
        <RowConstraints vgrow="NEVER"/>
      </rowConstraints>

      <Label text="Total" textAlignment="CENTER" GridPane.columnSpan="2"
        GridPane.halignment="CENTER">
        <font>
          <Font name="System Bold" size="18.0"/>
        </font>
      </Label>
      <Button defaultButton="true" mnemonicParsing="false" onAction="#save" prefWidth="90.0"
        text="Save"
        GridPane.halignment="RIGHT" GridPane.rowIndex="2"/>
      <Button cancelButton="true" mnemonicParsing="false" onAction="#cancel" prefWidth="90.0"
        text="Cancel"
        GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.rowIndex="2"/>

      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

  </GridPane>
</AnchorPane>
