<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="400.0" prefWidth="600.0"
  styleClass="modal" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.defragler.fixiqo.views.controllers.modals.ClientModalWindowController">
  <padding>
    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
  </padding>

  <!-- Window Content -->
  <GridPane alignment="CENTER" hgap="5.0" vgap="5.0" AnchorPane.bottomAnchor="0.0"
    AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
    <columnConstraints>
      <ColumnConstraints hgrow="NEVER"/>
      <ColumnConstraints hgrow="ALWAYS"/>
      <ColumnConstraints hgrow="NEVER"/>
    </columnConstraints>
    <rowConstraints>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>

    <!-- Client -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0">
      <columnConstraints>
        <ColumnConstraints hgrow="NEVER" prefWidth="50.0"/>
        <ColumnConstraints fillWidth="false" hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>

      <Label opacity="0.5" text="Client"/>
      <Label text="Name" GridPane.halignment="RIGHT" GridPane.rowIndex="1"/>
      <TextField fx:id="clientNameField" promptText="Full Name" GridPane.columnIndex="1"
        GridPane.rowIndex="1"/>

      <Label text="Number" GridPane.halignment="RIGHT" GridPane.rowIndex="2"/>
      <TextField fx:id="clientNumberField" promptText="Phone Number" GridPane.columnIndex="1"
        GridPane.rowIndex="2"/>
    </GridPane>

    <!-- Devices -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnIndex="1"
      GridPane.columnSpan="2">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS" prefWidth="50.0"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>

      <Label opacity="0.5" text="Devices"/>
      <TableView fx:id="devicesTable" GridPane.rowIndex="1">
        <columns>
          <TableColumn fx:id="deviceManufacturerColumn" prefWidth="150.0" text="Manufacturer"/>
          <TableColumn fx:id="deviceModelColumn" prefWidth="150.0" text="Model"/>
        </columns>
        <columnResizePolicy>
          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
      </TableView>
    </GridPane>

    <!-- Requests -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnSpan="2"
      GridPane.rowIndex="1">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>

      <Label opacity="0.5" text="Requests"/>
      <TableView fx:id="requestsTable" GridPane.rowIndex="1">
        <columns>
          <TableColumn fx:id="requestsIdColumn" prefWidth="40.0" text="№"/>
          <TableColumn fx:id="requestsStatusColumn" prefWidth="100.0" text="Status"/>
          <TableColumn fx:id="requestsDateColumn" prefWidth="100.0" text="Date"/>
        </columns>
        <columnResizePolicy>
          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
      </TableView>
    </GridPane>

    <!-- Actions -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnIndex="2"
      GridPane.rowIndex="1">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
        <RowConstraints vgrow="NEVER"/>
      </rowConstraints>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>

      <Label opacity="0.5" text="Actions"/>
      <HBox alignment="CENTER" spacing="5.0" GridPane.rowIndex="2">
        <Button defaultButton="true" mnemonicParsing="false" onAction="#save" prefWidth="90.0"
          text="Save"/>
        <Button cancelButton="true" mnemonicParsing="false" onAction="#cancel" prefWidth="90.0"
          text="Cancel"/>
      </HBox>
    </GridPane>
  </GridPane>
</AnchorPane>
