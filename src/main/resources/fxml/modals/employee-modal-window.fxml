<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="600.0" prefWidth="700.0"
  styleClass="modal" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.defragler.fixiqo.views.controllers.modals.EmployeeModalWindowController">
  <padding>
    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
  </padding>

  <!-- Window Content -->
  <GridPane alignment="CENTER" hgap="5.0" vgap="5.0" AnchorPane.bottomAnchor="0.0"
    AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
    <columnConstraints>
      <ColumnConstraints hgrow="ALWAYS"/>
      <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints prefHeight="300.0" vgrow="ALWAYS"/>
    </rowConstraints>

    <!-- Avatar Section -->
    <GridPane styleClass="bordered" vgap="5.0">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>
      <Label opacity="0.5" text="Avatar"/>
      <VBox alignment="TOP_CENTER" spacing="15.0" GridPane.rowIndex="1">
        <ImageView fx:id="avatarPreview"
          fitWidth="175"
          fitHeight="175"
          preserveRatio="true"
          smooth="true"/>

        <Button mnemonicParsing="false" onAction="#loadImage" prefWidth="100.0" text="Load image"/>
      </VBox>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Account Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnIndex="1">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>
      <Label opacity="0.5" text="Account"/>
      <VBox alignment="CENTER" fillWidth="false" spacing="15.0" GridPane.rowIndex="1">
        <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0">
          <Label alignment="CENTER" text="Username"/>
          <TextField fx:id="usernameField" promptText="Username"/>
        </VBox>
        <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0">
          <Label text="Password"/>
          <PasswordField fx:id="passwordField" promptText="Password"/>
        </VBox>
      </VBox>
      <VBox alignment="CENTER" fillWidth="false" spacing="15.0" GridPane.columnIndex="1"
        GridPane.rowIndex="1">
        <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0">
          <Label text="Email"/>
          <TextField fx:id="emailField" promptText="Email"/>
        </VBox>
        <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0">
          <Label text="Role"/>
          <ComboBox fx:id="roleField" promptText="Role"/>
        </VBox>
      </VBox>
      <Separator prefWidth="200.0" GridPane.columnSpan="2" GridPane.rowIndex="2"/>

      <!-- Actions Section -->
      <GridPane vgap="5.0" GridPane.columnSpan="2" GridPane.rowIndex="3">
        <columnConstraints>
          <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
          <RowConstraints vgrow="NEVER"/>
          <RowConstraints vgrow="ALWAYS"/>
        </rowConstraints>

        <HBox alignment="CENTER" spacing="5.0" GridPane.rowIndex="1">
          <Button defaultButton="true" mnemonicParsing="false" onAction="#save" prefWidth="100.0"
            text="Save"/>
          <Button cancelButton="true" mnemonicParsing="false" onAction="#cancel" prefWidth="100.0"
            text="Cancel"/>
        </HBox>
        <Label opacity="0.5" text="Actions"/>
      </GridPane>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
    </GridPane>

    <!-- Requests Section -->
    <GridPane hgap="5.0" styleClass="bordered" vgap="5.0" GridPane.columnSpan="2"
      GridPane.rowIndex="1">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>
      <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
      </padding>
      <Label opacity="0.5" text="Requests"/>
      <TableView fx:id="requestsTable" GridPane.rowIndex="1">
        <columns>
          <TableColumn fx:id="requestsIdColumn" prefWidth="40.0" text="№"/>
          <TableColumn fx:id="requestsStatusColumn" prefWidth="100.0" text="Status"/>
          <TableColumn fx:id="requestsDateColumn" prefWidth="100.0" text="Date"/>
        </columns>
        <columnResizePolicy>
          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
      </TableView>
    </GridPane>
  </GridPane>
</AnchorPane>
