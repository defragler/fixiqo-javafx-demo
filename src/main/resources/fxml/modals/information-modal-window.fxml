<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="400.0" prefWidth="300.0"
  styleClass="modal" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.defragler.fixiqo.views.controllers.modals.InformationModalWindowController">
  <padding>
    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
  </padding>

  <!-- Window Content -->
  <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
    AnchorPane.topAnchor="0.0">
    <columnConstraints>
      <ColumnConstraints hgrow="ALWAYS"/>
      <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES"/>
      <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>

    <!-- Application Info -->
    <VBox alignment="BOTTOM_CENTER" GridPane.columnIndex="1">
      <Label text="Fixiqo" textAlignment="CENTER" styleClass="label-header"/>
      <Label text="Version 1.0" textAlignment="CENTER"/>
      <Label opacity="0.5" text="by defragler" textAlignment="CENTER"/>
    </VBox>

    <!-- Application Description -->
    <Label contentDisplay="CENTER" prefWidth="230.0"
      text="Fixiqo is a modern UI-based system designed for service centers. It streamlines and automates the entire device repair workflow, including request management, client tracking, and staff coordination. With an intuitive interface and structured data handling, Fixiqo helps improve efficiency, reduce errors, and simplify daily operations."
      textAlignment="CENTER" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

    <!-- Additional Links -->
    <VBox alignment="TOP_CENTER" GridPane.columnIndex="1" GridPane.rowIndex="2">
      <Label opacity="0.5" text="Additional links"/>
      <HBox alignment="TOP_CENTER" spacing="5.0">
        <Hyperlink text="GitHub" onAction="#openGitHub"/>
        <Hyperlink text="Instagram" onAction="#openInstagram"/>
        <Hyperlink text="Discord" onAction="#openDiscord"/>
      </HBox>
    </VBox>

  </GridPane>
</AnchorPane>
