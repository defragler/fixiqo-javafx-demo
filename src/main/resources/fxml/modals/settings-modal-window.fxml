<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.ToggleSwitch?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ToggleButton?>
<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="200.0" prefWidth="200.0"
  styleClass="modal" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.defragler.fixiqo.views.controllers.modals.SettingsModalWindowController">
  <padding>
    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
  </padding>

  <!-- Window Content -->
  <GridPane alignment="CENTER" hgap="5.0" vgap="5.0" AnchorPane.bottomAnchor="0.0"
    AnchorPane.leftAnchor="0.0"
    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
    <columnConstraints>
      <ColumnConstraints halignment="CENTER" hgrow="ALWAYS"/>
      <ColumnConstraints halignment="CENTER" hgrow="NEVER"/>
      <ColumnConstraints halignment="CENTER" hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>

    <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0" GridPane.columnIndex="1">
      <Label alignment="CENTER" opacity="0.5" text="Language"/>
      <ComboBox fx:id="languageField" promptText="Language"/>
    </VBox>

    <VBox alignment="CENTER_LEFT" fillWidth="false" spacing="2.0" GridPane.columnIndex="1"
      GridPane.rowIndex="1">
      <Label alignment="CENTER" opacity="0.5" text="Theme"/>
      <HBox alignment="CENTER_LEFT">
        <ToggleButton fx:id="lightThemeButton" text="Light" styleClass="left-pill"/>
        <ToggleButton fx:id="autoThemeButton" text="Auto" styleClass="center-pill" selected="true"/>
        <ToggleButton fx:id="darkThemeButton" text="Dark" styleClass="right-pill"/>
      </HBox>
    </VBox>

    <Button defaultButton="true" mnemonicParsing="false" onAction="#save" prefWidth="100.0"
      text="Save" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
  </GridPane>
</AnchorPane>
