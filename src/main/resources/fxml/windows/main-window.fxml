<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.defragler.fixiqo.views.controllers.windows.MainWindowController">
  <AnchorPane prefHeight="700.0" prefWidth="1100.0">

    <!-- Window Content -->
    <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
      AnchorPane.topAnchor="0.0">
      <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS" maxWidth="-Infinity" minWidth="-Infinity"
          prefWidth="180.0"/>
        <ColumnConstraints hgrow="ALWAYS"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints vgrow="ALWAYS"/>
      </rowConstraints>

      <!-- Navigation Panel -->
      <GridPane vgap="10.0">
        <columnConstraints>
          <ColumnConstraints hgrow="ALWAYS"/>
          <ColumnConstraints hgrow="NEVER"/>
        </columnConstraints>
        <rowConstraints>
          <RowConstraints vgrow="NEVER"/>
          <RowConstraints vgrow="NEVER"/>
          <RowConstraints vgrow="ALWAYS"/>
          <RowConstraints vgrow="NEVER"/>
        </rowConstraints>

        <Separator orientation="VERTICAL" GridPane.columnIndex="1" GridPane.rowSpan="6">
          <padding>
            <Insets left="5.0"/>
          </padding>
        </Separator>

        <!-- User Account  -->
        <GridPane hgap="5.0">
          <columnConstraints>
            <ColumnConstraints/>
            <ColumnConstraints hgrow="ALWAYS"/>
            <ColumnConstraints/>
          </columnConstraints>
          <rowConstraints>
            <RowConstraints vgrow="NEVER"/>
          </rowConstraints>

          <!-- Avatar -->
          <ImageView fx:id="avatarImage"
            fitWidth="40"
            fitHeight="40"
            preserveRatio="true"/>

          <!-- Username & User Role -->
          <VBox alignment="CENTER" GridPane.columnIndex="1">
            <Label fx:id="usernameLabel" text="Username" translateY="5.0"/>
            <Separator/>
            <Label fx:id="roleLabel" opacity="0.75" text="UserRole" translateY="-5.0"/>
          </VBox>

          <!-- Account Settings -->
          <Button mnemonicParsing="false" onAction="#openAccountModal" styleClass="additional-small"
            text="⚙" GridPane.columnIndex="2"/>
        </GridPane>

        <Separator GridPane.rowIndex="1"/>

        <!-- Navigation -->
        <StackPane GridPane.rowIndex="2">
          <!-- Pointer -->
          <StackPane fx:id="pointer" alignment="TOP_LEFT">
            <Pane styleClass="pointer"/>
            <Pane styleClass="pointer-glow"/>
          </StackPane>

          <!-- Navigation buttons -->
          <VBox fx:id="navContainer" spacing="5.0">
            <ToggleButton fx:id="homeButton" styleClass="navigation-button" onAction="#openHomePage" text="Home"/>
            <ToggleButton fx:id="clientsButton" styleClass="navigation-button" onAction="#openClientsPage" text="Clients"/>
            <ToggleButton fx:id="requestsButton" styleClass="navigation-button" onAction="#openRequestsPage" text="Requests"/>
            <ToggleButton fx:id="employeesButton" styleClass="navigation-button" onAction="#openEmployeesPage" text="Employees"/>
            <ToggleButton fx:id="browserButton" styleClass="navigation-button" onAction="#openBrowserPage" text="Browser"/>
            <ToggleButton fx:id="storageButton" styleClass="navigation-button" onAction="#openStoragePage" text="Storage"/>
            <Separator/>
            <ToggleButton fx:id="settingsButton" styleClass="navigation-button" onAction="#openSettingsPage" text="Settings"/>
            <ToggleButton fx:id="informationButton" styleClass="navigation-button" onAction="#openInformationPage" text="Information"/>
          </VBox>
        </StackPane>

        <!-- Version Information -->
        <HBox alignment="BOTTOM_CENTER" GridPane.rowIndex="3">
          <Label opacity="0.5" styleClass="label-misc" text="Fixiqo v1.0" textAlignment="CENTER"/>
        </HBox>
      </GridPane>

      <!-- Pages Content -->
      <StackPane fx:id="contentPane" GridPane.columnIndex="1">
        <padding>
          <Insets left="5.0"/>
        </padding>
      </StackPane>
    </GridPane>

    <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
  </AnchorPane>
</StackPane>
