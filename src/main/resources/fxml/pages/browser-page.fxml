<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.ColumnConstraints?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.defragler.fixiqo.views.controllers.pages.BrowserPageController"
  prefHeight="680.0" prefWidth="900.0">
  <Label>BROWSER PAGE</Label>

  <!-- Page Content -->
  <GridPane hgap="5.0" vgap="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
    <columnConstraints>
      <ColumnConstraints hgrow="ALWAYS"/>
      <ColumnConstraints hgrow="ALWAYS"/>
      <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
      <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>
  </GridPane>
</AnchorPane>
